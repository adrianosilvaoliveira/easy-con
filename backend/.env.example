# Application
NODE_ENV=development
PORT=3333
API_URL=http://localhost:3333

# Database
DATABASE_URL=postgresql://hospital:hospital_secret@localhost:5432/hospital_stock?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Hospital
HOSPITAL_NAME=Hospital Oftalmológico Visão Clara
HOSPITAL_CNPJ=00.000.000/0001-00
HOSPITAL_ADDRESS=Rua da Saúde, 1000 - São Paulo, SP

# Email (password recovery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hospital.com

# CORS (opcional; padrão = API_URL — mesmo servidor)
# FRONTEND_URL=http://localhost:3333

# Vercel (definir no painel do projeto — serviço backend)
# CRON_SECRET=gerar-string-aleatoria-min-16-chars
# FRONTEND_URL=https://seu-dominio.vercel.app

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
