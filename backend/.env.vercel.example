# Prisma Postgres (Vercel Storage): aba ".env.local" -> copie as URLs COMPLETAS (nao use "...")

# Cole PRISMA_DATABASE_URL ou DATABASE_URL (uma linha inteira, com usuario:senha@host)
DATABASE_URL="postgres://SEU_USUARIO:SUA_SENHA@db.prisma.io:5432/postgres?sslmode=require"

# Cole POSTGRES_URL (pode ser a mesma URL se o painel mostrar igual)
DIRECT_URL="postgres://SEU_USUARIO:SUA_SENHA@db.prisma.io:5432/postgres?sslmode=require"
