# Copie do painel Vercel: Storage → seu Postgres → aba ".env.local" ou "Connect"
# Cole os valores reais abaixo e salve como .env.vercel (não commite este arquivo)

# Queries (pool) — use PRISMA_DATABASE_URL ou DATABASE_URL do painel
DATABASE_URL="postgresql://..."

# Migrations (conexão direta) — use POSTGRES_URL do painel
DIRECT_URL="postgresql://..."
