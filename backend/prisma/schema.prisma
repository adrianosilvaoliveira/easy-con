generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum RoleName {
  ADMINISTRADOR
  OPERACIONAL
  FARMACIA
  ESTOQUE
  AUDITOR
  VISUALIZADOR
}

enum StockLocationType {
  CENTRAL
  CENTRO_CIRURGICO
  CONSULTORIO
  FARMACIA
  SATELITE
}

enum MovementType {
  ENTRADA_COMPRA
  ENTRADA_MANUAL
  AJUSTE_ENTRADA
  DEVOLUCAO
  SAIDA_CONSUMO
  SAIDA_CIRURGIA
  SAIDA_CONSULTA
  SAIDA_PERDA
  SAIDA_VENCIMENTO
  TRANSFERENCIA
}

enum MovementStatus {
  PENDENTE
  APROVADA
  REJEITADA
  CONCLUIDA
}

enum InventoryStatus {
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT
}

enum ExpirationStatus {
  VALID
  WARNING
  CRITICAL
  EXPIRED
}

enum ExpirationAlertType {
  EXPIRED
  DAYS_90
  DAYS_60
  DAYS_30
  DAYS_7
}

// ==================== AUTH & USERS ====================

model User {
  id                String         @id @default(uuid())
  name              String
  email             String         @unique
  password          String
  active            Boolean        @default(true)
  roleId            String
  role              Role           @relation(fields: [roleId], references: [id])
  /** Quando true, usa permissões em customPermissions em vez do perfil */
  useCustomAccess   Boolean        @default(false)
  customPermissions UserPermission[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  auditLogs         AuditLog[]
  stockMovements    StockMovement[] @relation("MovementUser")
  approvedMovements StockMovement[] @relation("MovementApprover")
  inventories       Inventory[]
  createdBatches      ProductBatch[] @relation("BatchCreator")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        RoleName         @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      PermissionAction
  description String?
  roles       RolePermission[]
  users       UserPermission[]
  createdAt   DateTime         @default(now())

  @@unique([module, action])
  @@map("permissions")
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

// ==================== CATALOG ====================

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Supplier {
  id          String          @id @default(uuid())
  name        String
  cnpj        String?         @unique
  email       String?
  phone       String?
  address     String?
  active      Boolean         @default(true)
  movements   StockMovement[]
  batches     ProductBatch[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("suppliers")
}

model Product {
  id            String         @id @default(uuid())
  name          String
  internalCode  String         @unique
  barcode       String?
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  manufacturer  String?
  unit          String         @default("UN")
  minQuantity   Int            @default(0)
  location      String?
  notes         String?
  active        Boolean        @default(true)
  batches       ProductBatch[]
  stockItems    StockItem[]
  movements     StockMovement[]
  inventoryItems InventoryItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
  @@index([barcode])
  @@map("products")
}

model ProductBatch {
  id                String            @id @default(uuid())
  productId         String
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockLocationId   String            @map("stock_location_id")
  stockLocation     StockLocation     @relation(fields: [stockLocationId], references: [id])
  batchNumber       String            @map("batch_number")
  expirationDate    DateTime          @map("expiration_date")
  manufacturingDate DateTime?         @map("manufacturing_date")
  quantity          Int               @default(0)
  supplierId        String?           @map("supplier_id")
  supplier          Supplier?         @relation(fields: [supplierId], references: [id])
  unitCost          Decimal?          @map("unit_cost") @db.Decimal(12, 2)
  status            ExpirationStatus  @default(VALID)
  createdById       String?           @map("created_by")
  createdBy         User?             @relation("BatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  expirationAlerts  ExpirationAlert[]
  stockItems        StockItem[]
  movements         StockMovement[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([productId, stockLocationId, batchNumber])
  @@index([expirationDate])
  @@index([status])
  @@index([stockLocationId])
  @@map("product_batches")
}

model ExpirationAlert {
  id         String              @id @default(uuid())
  batchId    String              @map("batch_id")
  batch      ProductBatch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  alertType  ExpirationAlertType @map("alert_type")
  alertDate  DateTime            @default(now()) @map("alert_date")
  visualized Boolean             @default(false)
  createdAt  DateTime            @default(now())

  @@unique([batchId, alertType])
  @@index([visualized])
  @@index([alertDate])
  @@map("expiration_alerts")
}

// ==================== STOCK ====================

model StockLocation {
  id               String            @id @default(uuid())
  name             String
  code             String            @unique
  type             StockLocationType
  description      String?
  active           Boolean           @default(true)
  stockItems       StockItem[]
  originMovements  StockMovement[]   @relation("OriginLocation")
  destinationMovements StockMovement[] @relation("DestinationLocation")
  inventories      Inventory[]
  productBatches   ProductBatch[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("stock_locations")
}

model StockItem {
  id         String        @id @default(uuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  batchId    String?
  batch      ProductBatch? @relation(fields: [batchId], references: [id])
  quantity   Int           @default(0)
  updatedAt  DateTime      @updatedAt

  @@unique([productId, locationId, batchId])
  @@map("stock_items")
}

model StockMovement {
  id                    String         @id @default(uuid())
  type                  MovementType
  status                MovementStatus @default(CONCLUIDA)
  productId             String
  product               Product        @relation(fields: [productId], references: [id])
  batchId               String?
  batch                 ProductBatch?  @relation(fields: [batchId], references: [id])
  quantity              Int
  unitPrice             Decimal?       @db.Decimal(12, 2)
  totalValue            Decimal?       @db.Decimal(12, 2)
  originLocationId      String?
  originLocation        StockLocation? @relation("OriginLocation", fields: [originLocationId], references: [id])
  destinationLocationId String?
  destinationLocation   StockLocation? @relation("DestinationLocation", fields: [destinationLocationId], references: [id])
  supplierId            String?
  supplier              Supplier?      @relation(fields: [supplierId], references: [id])
  invoiceNumber         String?
  reason                String?
  notes                 String?
  movementDate          DateTime       @default(now())
  userId                String
  user                  User           @relation("MovementUser", fields: [userId], references: [id])
  approvedById          String?
  approvedBy            User?          @relation("MovementApprover", fields: [approvedById], references: [id])
  approvedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([type])
  @@index([movementDate])
  @@index([status])
  @@map("stock_movements")
}

// ==================== INVENTORY ====================

model Inventory {
  id          String          @id @default(uuid())
  locationId  String
  location    StockLocation   @relation(fields: [locationId], references: [id])
  status      InventoryStatus @default(EM_ANDAMENTO)
  notes       String?
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  items       InventoryItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("inventories")
}

model InventoryItem {
  id              String    @id @default(uuid())
  inventoryId     String
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  batchId         String?
  systemQuantity  Int
  countedQuantity Int
  divergence      Int
  adjusted        Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@map("inventory_items")
}

// ==================== ORGANIZATION ====================

model OrganizationSettings {
  id        String   @id @default("default")
  name      String
  cnpj      String?
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_settings")
}

// ==================== AUDIT ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  module     String
  entityId   String?
  entityType String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([module])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
