{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "framework": "express",
  "functions": {
    "api/cron/expiration.ts": {
      "maxDuration": 60,
      "includeFiles": "prisma/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/expiration",
      "schedule": "0 6 * * *"
    }
  ]
}
